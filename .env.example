# ── Copy this file to .env.local and fill in real values ──────────────────────
# Everything here is from FREE accounts. Nothing costs money.

# Supabase — supabase.com → your project → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Settings → API → service_role (SECRET — server only, used by indexer + cron). Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini (primary LLM) — aistudio.google.com → Get API key (free)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-key

# Groq (LLM failover + Whisper voice fallback) — console.groq.com (free). Optional but recommended.
GROQ_API_KEY=your-groq-key

# Shared secret that cron-job.org must send in the `x-cron-secret` header. Generate any random string.
CRON_SECRET=change-me-to-a-long-random-string

# Cloudflare Workers AI (edge embeddings + Whisper fallback for production). Optional locally.
# CF_ACCOUNT_ID=
# CF_WORKERS_AI_TOKEN=
